{
  "name": "mamarmite/uid-endpoint",
  "description": "Ajout d'un endpoint et d'identifiant unique pour les données structurées dans Wordpress. ",
  "version": "0.3.2",
  "type": "project",
  "authors": [
    {
      "name": "Marc-André Martin",
      "email": "marcandre@mamarmite.com"
    }
  ],
  "require": {
    "php": "^8.0"
  },
  "autoload": {
    "files": [
      "src/handlers.php",
      "src/rewrite.php",
      "src/actions.php",
      "src/filters.php"
    ],
    "psr-4": {
      "Mamarmite\\UIDEndpoint\\": "src/"
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true,
  "require-dev": {
    "wp-coding-standards/wpcs": "^3.0",
    "dealerdirect/phpcodesniffer-composer-installer": "^1.0",
    "phpstan/phpstan": "^2.2",
    "szepeviktor/phpstan-wordpress": "^2.0",
    "vimeo/psalm": "^6.5",
    "humanmade/psalm-plugin-wordpress": "^3.1"
  },
  "config": {
    "allow-plugins": {
      "dealerdirect/phpcodesniffer-composer-installer": true
    }
  }
}
